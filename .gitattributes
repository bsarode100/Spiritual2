# Normalize line endings to LF in repo (cross-platform safety)
* text=auto eol=lf
*.sh text eol=lf
*.php text eol=lf
*.css text eol=lf
*.js text eol=lf
*.sql text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
Dockerfile text eol=lf

# Binaries
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.ico binary
